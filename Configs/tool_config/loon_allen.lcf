广告拦截 = select,REJECT,DIRECT,Proxy,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Advertising.png

[Remote Filter]
# 远程筛选器区：根据订阅节点名称筛出地区节点。
# 新增地区时：先在这里添加筛选器，再到 [Proxy Group] 新增对应地区组。
# exclude 条件用于排除回国、校园、游戏等不适合通用代理的节点。
All Server = NameRegex, FilterKey = "^(?=.*(.*))(?!.*((?i)邀请|返利|循环|官网|客服|网站|网址|获取|订阅|流量|到期|机场|下次|版本|官址|备用|到期|过期|已用|联系|邮箱|工单|群|贩卖|倒卖|防止|国内|🎮|(\b(GAME|USE|USED|TOTAL|EXPIRE|EMAIL|Panel)\b|(\d{4}-\d{2}-\d{2}|\dG)))).*$"
香港 = NameRegex, FilterKey = "^(?=.*((?i)🇭🇰|香港|(\b(HK|HKG|Hong)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
台湾 = NameRegex, FilterKey = "^(?=.*((?i)🇹🇼|台湾|(\b(TW|TWN|Tai|Taiwan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
日本 = NameRegex, FilterKey = "^(?=.*((?i)🇯🇵|日本|川日|东京|大阪|泉日|埼玉|(\b(JP|JPN|Japan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
韩国 = NameRegex, FilterKey = "^(?=.*((?i)🇰🇷|韩国|韓|首尔|(\b(KR|KOR|Korea)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
美国 = NameRegex, FilterKey = "^(?=.*((?i)🇺🇸|美国|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|(\b(US|USA|United States)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
新加坡 = NameRegex, FilterKey = "^(?=.*((?i)🇸🇬|新加坡|狮城|(\b(SG|SGP|Singapore)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
英国 = NameRegex, FilterKey = "^(?=.*((?i)🇬🇧|英国|伦敦|(\b(UK|GB|GBR|United Kingdom)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"

[Proxy Chain]
# 代理链区：当前未使用。只有需要“节点 A 经节点 B 转发”时才在这里配置。
[Rule]
# 本地规则区：优先级高于远程规则，适合放个人域名、特殊站点和需要立即覆盖的规则。
# 格式：规则类型,匹配内容,策略组[,no-resolve]
# 注意：同一域名不要重复写多条不同策略；Loon 会按从上到下先匹配先生效。
# === 本地自定义规则 ===
# 1. 局域网与管理规则 (最高优先级)
# Loon 不支持按源 IP 地址分流；qB 下载器直连由网关 Mihomo 处理。

# 2. Apple 与系统服务
DOMAIN-SUFFIX,push.apple.com,香港节点
# Apple 关键词规则容易覆盖其它 Apple 分流，继续禁用。
# DOMAIN-KEYWORD,apple,DIRECT

# 3. 直连与 PT 服务
# 已纳入远程 PT 订阅的站点不在本地重复维护。
DOMAIN-SUFFIX,synology.cn,DIRECT
DOMAIN,qbittorrent-nox,DIRECT
DOMAIN-SUFFIX,digitalocean.com,DIRECT
DOMAIN-SUFFIX,dyndns.com,DIRECT
DOMAIN-SUFFIX,whatismyip.akamai.com,DIRECT
DOMAIN-KEYWORD,volcengine,DIRECT
DOMAIN-SUFFIX,xmwsyy.com,DIRECT
DOMAIN-SUFFIX,ui.com,DIRECT
DOMAIN-SUFFIX,imgse.com,DIRECT
DOMAIN-SUFFIX,tagweb.vip,DIRECT
DOMAIN-KEYWORD,yqc-premium,DIRECT
DOMAIN-SUFFIX,ad.12306.cn,DIRECT
DOMAIN-SUFFIX,gg.caixin.com,DIRECT
DOMAIN-SUFFIX,sdkapp.uve.weibo.com,DIRECT
DOMAIN-SUFFIX,ucweb.com,DIRECT
DOMAIN-SUFFIX,snssdk.com,DIRECT
DOMAIN-SUFFIX,amemv.com,DIRECT
DOMAIN-SUFFIX,v4.plex.tv,DIRECT

# 4. 技术开发与工具
